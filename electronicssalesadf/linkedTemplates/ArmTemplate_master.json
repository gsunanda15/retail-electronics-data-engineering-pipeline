{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "electronicssalesadf"
		},
		"AzureDatabricks_LS_accessToken": {
			"type": "secureString",
			"metadata": "Secure string for 'accessToken' of 'AzureDatabricks_LS'"
		},
		"electronicsdatalakeLS_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'electronicsdatalakeLS'"
		},
		"electronicssqldbLS_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'electronicssqldbLS'"
		},
		"electronicsdatalakeLS_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://electronicsdatalake.dfs.core.windows.net/"
		},
		"electronicssqldbLS_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "electronicsserver.database.windows.net"
		},
		"electronicssqldbLS_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "electronicsdb"
		},
		"electronicssqldbLS_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "adminsunanda"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "electronicssalesadf_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"AzureDatabricks_LS_accessToken": {
						"value": "[parameters('AzureDatabricks_LS_accessToken')]"
					},
					"electronicsdatalakeLS_accountKey": {
						"value": "[parameters('electronicsdatalakeLS_accountKey')]"
					},
					"electronicssqldbLS_password": {
						"value": "[parameters('electronicssqldbLS_password')]"
					},
					"electronicsdatalakeLS_properties_typeProperties_url": {
						"value": "[parameters('electronicsdatalakeLS_properties_typeProperties_url')]"
					},
					"electronicssqldbLS_properties_typeProperties_server": {
						"value": "[parameters('electronicssqldbLS_properties_typeProperties_server')]"
					},
					"electronicssqldbLS_properties_typeProperties_database": {
						"value": "[parameters('electronicssqldbLS_properties_typeProperties_database')]"
					},
					"electronicssqldbLS_properties_typeProperties_userName": {
						"value": "[parameters('electronicssqldbLS_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}